# Copier ce fichier en `.env` et renseigner les valeurs.
# Sans ces variables, l'app tourne en "mode local" (points en mémoire, pas de base).

# Projet Supabase (Settings > API dans le dashboard Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optionnel : clé MapTiler pour un fond vectoriel (le fond IGN fonctionne sans clé)
VITE_MAPTILER_KEY=

# Jeton Mapillary pour la "Vue rue" en secours (gratuit : mapillary.com/dashboard/developers)
VITE_MAPILLARY_TOKEN=

# Clé Google Maps pour la "Vue rue" navigable (Street View). Activer "Maps JavaScript API".
VITE_GOOGLE_MAPS_KEY=
